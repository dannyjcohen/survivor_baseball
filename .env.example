# Copy to .env and adjust for your environment
DB_HOST=127.0.0.1
DB_NAME=survivorbaseball
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# URL path prefix (no trailing slash). Leave EMPTY if the vhost document root is /public.
# Example subfolder install: APP_BASE_PATH=/survivorbaseball/public
APP_BASE_PATH=

# Timezone for display (server should use UTC; PHP converts for display)
APP_TIMEZONE=America/New_York

# MLB Stats API (default is official statsapi.mlb.com — no key required)
# MLB_STATS_API_BASE_URL=https://statsapi.mlb.com/api/v1
# Regular season year for pitcher W–L / ERA lines (defaults to current calendar year)
# MLB_SEASON_YEAR=2026

# Optional: protect daily.php — set a random string and use ?key=… or the form
# DAILY_SYNC_KEY=

# Automatic MLB sync (yesterday+today) once per calendar day on first web hit — requires app_meta table
# AUTO_DAILY_SYNC=1

# The Odds API — https://the-odds-api.com/ (get a key; never commit real keys)
# ODDS_API_KEY=
# ODDS_API_BASE_URL=https://api.the-odds-api.com/v4
# ODDS_SPORT_KEY=baseball_mlb
# ODDS_CACHE_TTL_SECONDS=21600
